# ─── Discord Application ──────────────────────────────────────────────────────
# Créer sur : https://discord.com/developers/applications
DISCORD_CLIENT_ID=VOTRE_CLIENT_ID
DISCORD_CLIENT_SECRET=VOTRE_CLIENT_SECRET

# URL de callback — en local : http://localhost:3000/auth/callback
# En prod (Railway) : https://votre-app.railway.app/auth/callback
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback

# ─── Serveur Discord (guilde) ─────────────────────────────────────────────────
# Clic droit sur le serveur → "Copier l'identifiant du serveur" (mode développeur activé)
DISCORD_GUILD_ID=VOTRE_GUILD_ID

# IDs des rôles autorisés (Primarques, Astartes)
# Clic droit sur le rôle dans Paramètres → "Copier l'identifiant du rôle"
ALLOWED_ROLE_IDS=ID_ROLE_PRIMARQUES,ID_ROLE_ASTARTES

# ─── Sécurité session ─────────────────────────────────────────────────────────
# Chaîne aléatoire longue — ex: openssl rand -hex 32
SESSION_SECRET=changez_moi_avec_une_chaine_aleatoire_longue

# ─── Addon (GitHub) ───────────────────────────────────────────────────────────
# Lien de téléchargement — toujours la dernière version de main
ADDON_DOWNLOAD_URL=https://github.com/AlexDN-dev/LamentersHelper/archive/refs/heads/main.zip

PORT=3000
